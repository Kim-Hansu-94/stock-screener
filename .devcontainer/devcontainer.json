{
  "name": "Stock Screener",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "postStartCommand": "mkdir -p /tmp/.next-cache/stock-screener-frontend && ln -sfn /workspaces/stock-screener/frontend/node_modules /tmp/.next-cache/stock-screener-frontend/node_modules",
  "postAttachCommand": "cd frontend && npm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/python/current/bin/python"
      }
    }
  }
}
